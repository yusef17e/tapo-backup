# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Tapo account credentials
TAPO_EMAIL=your@email.com
TAPO_PASSWORD=your_tapo_password

# Camera IPs (find in Tapo app: Settings → Device Info → IP Address)
CAMERA_IP_1=192.168.0.X
CAMERA_IP_2=192.168.0.X

# Friend's server SSH details
SSH_HOST=server.example.com
SSH_PORT=22
SSH_USER=username
SSH_PASSWORD=your_ssh_password
# OR use key-based auth:
# SSH_KEY_PATH=~/.ssh/id_rsa

# Remote folder on server where footage is stored
SSH_REMOTE_DIR=/home/username/tapo-footage
