# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Camera account password (same for all cameras)
# Find it in the Tapo app: tap camera → gear → Advanced Settings → Camera Account
TAPO_PASSWORD=your_camera_account_password

# Friend's server SSH details
SSH_HOST=server.example.com
SSH_PORT=22
SSH_USER=username
SSH_PASSWORD=your_ssh_password
# OR use key-based auth instead of password:
# SSH_KEY_PATH=~/.ssh/id_rsa

# Remote folder on server where footage is stored
SSH_REMOTE_DIR=/home/username/tapo-footage
